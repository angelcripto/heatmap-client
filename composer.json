{
    "name": "elbunkerbitcoin/heatmap-client",
    "description": "Cliente PHP oficial para integrar el heatmap de liquidaciones de El Búnker Bitcoin (CDN). Firma presigned URLs con HMAC para que el browser pueda consumir /api/heatmap/* sin exponer credenciales.",
    "type": "library",
    "license": "proprietary",
    "homepage": "https://elbunkerbitcoin.com",
    "keywords": ["heatmap", "liquidations", "trading", "crypto", "elbunker", "cdn"],
    "authors": [
        {
            "name": "El Búnker Bitcoin",
            "homepage": "https://elbunkerbitcoin.com"
        }
    ],
    "support": {
        "email": "soporte@elbunkerbitcoin.com",
        "source": "https://github.com/angelcripto/heatmap-client"
    },
    "require": {
        "php": "^7.4|^8.0",
        "ext-json": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "ElBunkerBitcoin\\HeatmapClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ElBunkerBitcoin\\HeatmapClient\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
